# Server
PORT=8787
HOST=127.0.0.1
REDDIX_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
REDDIX_DATA_DIR=.reddix-data
REDDIX_STATIC_DIR=./dist
REDDIX_MAX_OUTPUT_BYTES=10485760

